---
export const prerender = false;
import { generateCsrfToken } from '../../lib/auth';

// Wenn bereits eingeloggt → zum Dashboard
const sessionToken = Astro.cookies.get('session_token')?.value;
if (sessionToken) {
  const { validateSession } = await import('../../lib/auth');
  if (validateSession(sessionToken)) {
    return Astro.redirect('/admin/');
  }
}

const csrfToken = generateCsrfToken();
const error = Astro.url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  credentials: 'E-Mail oder Passwort ist falsch.',
  missing: 'Bitte E-Mail und Passwort eingeben.',
  invalid: 'Ungültige Eingabe.',
  csrf: 'Sitzung abgelaufen. Bitte erneut versuchen.',
  server: 'Ein Fehler ist aufgetreten. Bitte erneut versuchen.',
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Anmelden — Babi Yoga Admin</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <style>
      :root {
        --wine: #781d4c;
        --wine-dark: #5e1639;
        --gold: #e9a825;
        --cream: #f7ecf9;
        --sand: #f0e8f1;
        --night: #292420;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Work Sans', system-ui, -apple-system, sans-serif;
        background: var(--cream);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }
      .login-card {
        background: white;
        border-radius: 16px;
        padding: 2.5rem;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 4px 24px rgba(120, 29, 76, 0.08);
        border: 1px solid var(--sand);
      }
      .login-brand {
        text-align: center;
        margin-bottom: 2rem;
      }
      .login-brand h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.5rem;
        color: var(--wine);
        margin-bottom: 0.25rem;
      }
      .login-brand p {
        font-size: 0.875rem;
        color: #756d65;
      }
      .form-group {
        margin-bottom: 1.25rem;
      }
      .form-group label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--night);
        margin-bottom: 0.375rem;
      }
      .form-group input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--sand);
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        color: var(--night);
        transition: border-color 0.2s;
      }
      .form-group input:focus {
        outline: none;
        border-color: var(--wine);
        box-shadow: 0 0 0 3px rgba(120, 29, 76, 0.1);
      }
      .btn-login {
        width: 100%;
        padding: 0.875rem;
        background: var(--wine);
        color: white;
        border: none;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 0.5rem;
      }
      .btn-login:hover { background: var(--wine-dark); }
      .error-msg {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.875rem;
        margin-bottom: 1.25rem;
        text-align: center;
      }
      .login-footer {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.8125rem;
        color: #756d65;
      }
    </style>
  </head>
  <body>
    <div class="login-card">
      <div class="login-brand">
        <h1>Babi Yoga</h1>
        <p>Admin-Bereich</p>
      </div>

      {error && errorMessages[error] && (
        <div class="error-msg">{errorMessages[error]}</div>
      )}

      <form method="POST" action="/api/auth/login">
        <input type="hidden" name="_csrf" value={csrfToken} />

        <div class="form-group">
          <label for="email">E-Mail</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            maxlength="254"
            autocomplete="email"
            placeholder="ihre@email.de"
          />
        </div>

        <div class="form-group">
          <label for="password">Passwort</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            maxlength="128"
            autocomplete="current-password"
          />
        </div>

        <button type="submit" class="btn-login">Anmelden</button>
      </form>

      <div class="login-footer">
        <a href="/" style="color: var(--wine); text-decoration: none;">← Zurück zur Website</a>
      </div>
    </div>
  </body>
</html>
