---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const concerns = [
  { title: 'Stress & Erschöpfung' },
  { title: 'Darmgesundheit & Verdauung' },
  { title: 'Gewichtsregulation & Detox' },
  { title: 'Hautprobleme' },
  { title: 'Hormonelle Veränderungen' },
  { title: 'Gesund älter werden' },
];

const services = [
  'Psychologische Beratung',
  'Ayurvedische Gesundheits- und Ernährungsberatung',
  'Detox- und Regenerationskuren',
  'Konstitutionsbestimmung',
  'Individueller Behandlungsplan',
  'Ayurvedische Massagen',
  'Meditation, Atem- und Entspannungsübungen',
  'Yoga',
];

const massages = [
  { name: 'Massage für Frauen', description: 'Speziell abgestimmt bei Kinderwunsch, in der Schwangerschaft oder den Wechseljahren.' },
  { name: 'Teilkörpermassagen', description: 'Gesicht, Füße oder Rücken — gezielt dort, wo es nötig ist.' },
  { name: 'Honigmassage', description: 'Entgiftend und durchblutungsfördernd mit reinem Honig.' },
  { name: 'Kräuterpulvermassage', description: 'Anregend und straffend mit ayurvedischen Kräutern.' },
  { name: 'Seidenhandschuhmassage', description: 'Sanft belebend, ideal für empfindliche Haut.' },
  { name: 'Katibasti', description: 'Ölanwendung für den unteren Rücken — wohltuend bei Verspannungen.' },
];
---

<Layout
  title="Ayurveda & Massagen — Babi Yoga in Neu Wulmstorf"
  description="Ayurvedische Beratung und Massagen in Neu Wulmstorf. Abhyanga-Ganzkörpermassage, Ernährungsberatung, Detox-Kuren und psychologische Beratung."
>
  <PageHero
    title="Ayurveda & Massagen"
    subtitle="Ganzheitliche Begleitung für Körper, Geist und Wohlbefinden."
    backgroundImage="/images/massage.webp"
  />

  <!-- Anliegen -->
  <section class="section-padding bg-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="fade-in font-heading text-2xl font-bold text-dark mb-8 text-center">Was ist dein Anliegen?</h2>
      <div class="fade-in flex flex-wrap justify-center gap-3">
        {concerns.map((item) => (
          <span class="inline-block px-5 py-2.5 rounded-full bg-wine/8 text-wine text-sm font-medium">
            {item.title}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Services + Abhyanga -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Services List -->
        <div class="fade-in-left">
          <h3 class="font-heading text-xl font-bold text-dark mb-6">
            Mein Schwerpunkt: Vorsorge und Selbstfürsorge
          </h3>
          <ul class="space-y-3">
            {services.map((service) => (
              <li class="flex items-start gap-3 text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-wine mt-2.5 flex-shrink-0"></span>
                <span>{service}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/kontakt" class="btn btn-outline">Kostenfreie Erstberatung</a>
          </div>
        </div>

        <!-- Bild rechts -->
        <div class="fade-in-right">
          <div class="relative overflow-hidden rounded-2xl">
            <img
              src="/images/beratung.webp"
              alt="Ayurvedische Beratung und Massage-Umgebung"
              loading="lazy"
              decoding="async"
              class="w-full aspect-[4/3] object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Abhyanga Highlight — mittig -->
      <div class="fade-in max-w-2xl mx-auto mt-16 relative p-8 sm:p-10 bg-gradient-to-br from-wine/5 to-gold/5 rounded-2xl border border-wine/10 text-center">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-gold text-charcoal text-xs font-bold rounded-full">
          Beliebteste Behandlung
        </span>
        <h3 class="font-heading text-2xl font-bold text-dark mb-3 mt-2">Abhyanga</h3>
        <p class="font-heading italic text-wine text-lg mb-4">
          „Liebende Hände"
        </p>
        <p class="text-charcoal/80 leading-relaxed">
          Abhyanga ist die Königin der Massagen und eine der effektivsten Behandlungsformen
          der ayurvedischen Gesundheitslehre. Für jede Behandlung verwende ich individuell
          auf dich abgestimmte, hochwertige biologische Öle. Wohltuende Massagetechniken
          verschmelzen ineinander, was eine tiefe Entspannung, Regeneration und Vitalisierung
          des ganzen Körpers bewirkt.
        </p>
        <a href="/kontakt" class="btn btn-primary mt-6">Massage buchen</a>
      </div>
    </div>
  </section>

  <!-- Weitere Massagen -->
  <section class="section-padding bg-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="fade-in font-heading text-xl font-bold text-dark mb-8 text-center">Weitere Massagen</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger">
        {massages.map((massage) => (
          <div class="fade-in p-5 bg-white rounded-xl border border-sand-dark hover:border-wine/20 transition-colors duration-300">
            <h4 class="font-bold text-dark mb-1">{massage.name}</h4>
            <p class="text-sm text-gray-muted">{massage.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="fade-in font-heading text-2xl font-bold text-dark mb-4">Bereit für deine Auszeit?</h2>
      <p class="fade-in text-charcoal/80 text-lg mb-8">
        Lass uns gemeinsam herausfinden, welche Behandlung am besten zu dir passt.
        Die Erstberatung ist kostenfrei und unverbindlich.
      </p>
      <div class="fade-in flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="btn btn-primary">Kostenfreie Erstberatung</a>
        <a href="/kontakt" class="btn btn-outline">Massage buchen</a>
      </div>
    </div>
  </section>
</Layout>
