---
import { getActiveAnnouncements } from '../lib/db';

const announcements = getActiveAnnouncements() as any[];
const items = announcements.map(a => ({
  text: a.title,
  link: a.link || null,
}));
---

{items.length > 0 && (
  <div class="ticker-wrapper py-3">
    <div class="ticker-track">
      {[...items, ...items].map((item) => (
        <span class="inline-flex items-center gap-4 px-8 text-sm font-medium whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-gold flex-shrink-0"></span>
          {item.link ? (
            <a href={item.link} class="hover:text-gold transition-colors">{item.text}</a>
          ) : (
            item.text
          )}
        </span>
      ))}
    </div>
  </div>
)}
