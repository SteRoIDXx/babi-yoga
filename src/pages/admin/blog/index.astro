---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAllPosts, deletePost } from '../../../lib/db';
import { validateCsrfToken, generateCsrfToken } from '../../../lib/auth';

// Handle DELETE
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');
  const csrf = formData.get('_csrf') as string;

  if (validateCsrfToken(csrf) && action === 'delete') {
    const id = Number(formData.get('id'));
    if (id) deletePost(id);
  }
}

const posts = getAllPosts() as any[];
const csrfToken = generateCsrfToken();
const success = Astro.url.searchParams.get('success');
---

<AdminLayout title="Blog" activeNav="blog">
  <div class="flex items-center justify-between mb-6">
    <h1 class="page-title" style="margin-bottom: 0;">Blog-Beiträge</h1>
    <a href="/admin/blog/new" class="btn btn-primary">+ Neuer Beitrag</a>
  </div>

  {success === 'created' && <div class="alert alert-success">Beitrag erfolgreich erstellt!</div>}
  {success === 'updated' && <div class="alert alert-success">Beitrag erfolgreich aktualisiert!</div>}
  {success === 'deleted' && <div class="alert alert-success">Beitrag gelöscht.</div>}

  {posts.length === 0 ? (
    <div class="card" style="text-align: center; padding: 3rem;">
      <p style="color: var(--gray-muted); margin-bottom: 1rem;">Noch keine Blog-Beiträge vorhanden.</p>
      <a href="/admin/blog/new" class="btn btn-primary">Ersten Beitrag schreiben</a>
    </div>
  ) : (
    <div class="card" style="padding: 0; overflow: hidden;">
      <table>
        <thead>
          <tr>
            <th>Titel</th>
            <th>Status</th>
            <th>Datum</th>
            <th style="width: 120px;">Aktionen</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post: any) => (
            <tr>
              <td>
                <a href={`/admin/blog/${post.id}`} style="color: var(--wine); text-decoration: none; font-weight: 500;">
                  {post.title}
                </a>
                {post.image && <span style="margin-left: 0.5rem; opacity: 0.5;">🖼</span>}
                {post.video_url && <span style="margin-left: 0.25rem; opacity: 0.5;">🎬</span>}
              </td>
              <td>
                {post.published
                  ? <span class="badge badge-green">Veröffentlicht</span>
                  : <span class="badge badge-gray">Entwurf</span>
                }
              </td>
              <td class="text-sm text-muted">
                {post.published_at
                  ? new Date(post.published_at).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' })
                  : '–'
                }
              </td>
              <td>
                <div class="flex gap-2">
                  <a href={`/admin/blog/${post.id}`} class="btn btn-secondary btn-sm">Bearbeiten</a>
                  <form method="POST" style="display:inline;" onsubmit="return confirm('Beitrag wirklich löschen?')">
                    <input type="hidden" name="_csrf" value={csrfToken} />
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={post.id} />
                    <button type="submit" class="btn btn-danger btn-sm">×</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
