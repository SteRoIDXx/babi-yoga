---

<footer class="bg-wine text-white/80">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <div class="mb-6">
          <a href="/" class="inline-block" aria-label="Zur Startseite">
            <span class="font-heading text-3xl font-bold text-white tracking-wide">
              B&thinsp;A&thinsp;B&thinsp;I
            </span>
            <span class="block font-body text-xs font-semibold tracking-[0.3em] uppercase text-gold mt-1">
              Yoga
            </span>
          </a>
        </div>
        <address class="not-italic text-sm space-y-1 text-white/70">
          <p>Fischbeker Str. 4</p>
          <p>21629 Neu Wulmstorf</p>
          <p class="mt-3">
            <a href="tel:+491715884552" class="hover:text-gold transition-colors min-h-[44px] inline-flex items-center">0171 588 4552</a>
          </p>
        </address>
        <p class="mt-4 text-sm text-white/70">
          Nikola Babi — Stressmanagement · Selbstregulation
          <br />
          <a href="https://www.nikola-babi.de" target="_blank" rel="noopener noreferrer" class="text-gold/70 hover:text-gold transition-colors">
            www.nikola-babi.de
          </a>
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-heading font-bold text-white text-lg mb-5">Entdecken</h4>
        <ul class="space-y-1">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-gold transition-colors duration-300 min-h-[44px] inline-flex items-center py-1">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social & Legal -->
      <div>
        <h4 class="font-heading font-bold text-white text-lg mb-5">Verbinden</h4>

        <!-- Social Icons -->
        <div class="flex gap-3 mb-8">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${social.label} (öffnet in neuem Tab)`}
              class="w-11 h-11 rounded-full bg-white/10 flex items-center justify-center hover:bg-wine transition-colors duration-300"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>

        <!-- Newsletter -->
        <div class="mb-8">
          <h5 class="text-sm font-semibold text-white mb-2">Newsletter</h5>
          <p class="text-xs text-white/60 mb-3">Neuigkeiten, Termine und Inspirationen direkt in dein Postfach.</p>
          <a
            href="mailto:info@babi-yoga.com?subject=Newsletter-Anmeldung&body=Hallo%20Nikola%2C%0A%0Aich%20m%C3%B6chte%20mich%20gerne%20f%C3%BCr%20den%20Babi-Yoga%20Newsletter%20anmelden.%0A%0AName%3A%20%0AE-Mail%3A%20%0A%0AHerzliche%20Gr%C3%BC%C3%9Fe"
            class="inline-block px-4 py-2 text-xs font-semibold text-white border border-white/30 rounded-full hover:bg-white/10 transition-colors min-h-[44px] leading-[44px]"
          >
            Zum Newsletter anmelden
          </a>
        </div>

        <!-- Legal Links -->
        <ul class="space-y-1">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-white/80 transition-colors duration-300 min-h-[44px] inline-flex items-center py-1">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/60">
        &copy; {new Date().getFullYear()} Babi-Yoga. Alle Preise inkl. der gesetzlichen MwSt.
      </p>
      <p class="text-xs text-white/50">
        Webdesign von <a href="https://rohwer-webdesign.de" target="_blank" rel="noopener" class="text-gold/70 hover:text-gold transition-colors">Rohwer Webdesign</a>
      </p>
    </div>
  </div>
</footer>
