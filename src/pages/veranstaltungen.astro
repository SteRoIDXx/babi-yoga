---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getPublishedEvents, getCurrentAndUpcomingHolidays } from '../lib/db';

const dbEvents = getPublishedEvents() as any[];

// Events aus DB in Template-Format umwandeln
const dateFormatter = new Intl.DateTimeFormat('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
const weekdayFormatter = new Intl.DateTimeFormat('de-DE', { weekday: 'long' });

const events = dbEvents.map((e, i) => {
  const start = new Date(e.date_start);
  const end = e.date_end ? new Date(e.date_end) : null;

  // Datumsanzeige formatieren
  let dateDisplay: string;
  let weekday: string;
  if (end && e.date_end !== e.date_start) {
    dateDisplay = `${start.getDate()}. – ${dateFormatter.format(end)}`;
    weekday = ''; // Mehrtägig — kein einzelner Wochentag
  } else {
    dateDisplay = dateFormatter.format(start);
    weekday = weekdayFormatter.format(start);
  }

  return {
    date: dateDisplay,
    isoDate: start.toISOString(),
    isoEndDate: end && e.date_end !== e.date_start ? end.toISOString() : null,
    weekday,
    title: e.title,
    description: e.description,
    location: e.location || 'Babi-Yoga, Fischbeker Str. 4, Neu Wulmstorf',
    image: e.image,
    highlight: i === 0, // Erstes Event ist hervorgehoben
    cta: { label: 'Jetzt anmelden', href: '/kontakt' },
  };
});

const eventSchemas = events.map((event) => ({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": event.title,
  "startDate": event.isoDate,
  ...(event.isoEndDate && { "endDate": event.isoEndDate }),
  "description": event.description,
  "location": {
    "@type": "Place",
    "name": event.location.split(',')[0].trim(),
    "address": event.location
  },
  "organizer": {
    "@type": "Person",
    "name": "Nikola Babi",
    "url": "https://babi-yoga.com"
  },
}));

// Ferien aus DB
const ferienRaw = getCurrentAndUpcomingHolidays() as any[];
const ferienDateFmt = new Intl.DateTimeFormat('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
const ferien = ferienRaw.map((f: any) => ({
  name: f.name,
  range: `${ferienDateFmt.format(new Date(f.date_start + 'T00:00:00'))} – ${ferienDateFmt.format(new Date(f.date_end + 'T00:00:00'))}`,
  status: f.status,
  note: f.note,
}));
---

<Layout
  title="Veranstaltungen — Babi Yoga"
  description="Workshops, Mantra-Singkreise und Events bei Babi Yoga in Neu Wulmstorf. Aktuelle Termine und Veranstaltungen."
>
  <PageHero
    title="Veranstaltungen"
    subtitle="Workshops, Singkreise und besondere Events."
    backgroundImage="/images/yoga-gruppe.webp"
    imagePosition="center 18%"
  />

  <!-- Event Schema (SEO) -->
  {eventSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- Intro -->
  <section class="section-padding bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="fade-in text-charcoal/85 text-lg leading-relaxed">
        Neben den regulären Yogakursen biete ich regelmäßig besondere Events an —
        Mantra-Singkreise, Retreats und Workshops. Hier findest du die aktuellen Termine.
      </p>
    </div>
  </section>

  <!-- Events -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6 stagger">
      {events.map((event) => (
        <div class={`fade-in rounded-2xl overflow-hidden border ${event.highlight ? 'border-wine/15 bg-white shadow-md' : 'border-sand-dark bg-white'}`}>
          {event.highlight && event.image && (
            <div class="aspect-[16/9] overflow-hidden">
              <img src={event.image} alt={event.title} loading="lazy" decoding="async" class="w-full h-full object-cover object-top" />
            </div>
          )}
          <div class="flex flex-col sm:flex-row">
            <div class="sm:w-36 p-5 bg-wine/5 flex flex-col items-center justify-center text-center flex-shrink-0">
              {event.weekday && <span class="text-xs font-semibold text-wine uppercase tracking-wider">{event.weekday}</span>}
              <span class="font-heading text-lg font-bold text-dark mt-1">{event.date}</span>
            </div>
            <div class="flex-1 p-5 sm:p-6">
              <h3 class="font-heading text-xl font-bold text-dark mb-2">{event.title}</h3>
              <p class="text-charcoal/80 text-sm leading-relaxed mb-3">{event.description}</p>
              <div class="flex items-center justify-between flex-wrap gap-3">
                <div class="flex items-center gap-2 text-xs text-gray-muted">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  {event.location}
                </div>
                {event.cta && (
                  <a href={event.cta.href} class={`${event.highlight ? 'inline-block px-5 py-2 bg-wine text-white text-sm font-semibold rounded-full hover:bg-magenta transition-colors' : 'text-sm font-semibold text-wine hover:text-magenta transition-colors'}`}>
                    {event.cta.label}{!event.highlight && ' →'}
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Ferien -->
  {ferien.length > 0 && (
    <section class="py-12 bg-cream">
      <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="fade-in p-6 bg-white rounded-xl border border-sand-dark text-center">
          <h4 class="font-heading font-bold text-dark mb-3">Aktuelle Ferien, Feiertage & Pausen</h4>
          <p class="text-sm text-gray-muted mb-4">Bitte beachte die folgenden Termine — der Kursbetrieb kann eingeschränkt sein oder regulär weiterlaufen.</p>
          <div class="flex flex-col gap-2">
            {ferien.map((f) => (
              <div class="px-4 py-2.5 bg-sand rounded-lg text-sm">
                <div class="flex items-center justify-center gap-2 flex-wrap">
                  <span class="font-semibold text-dark">{f.name}</span>
                  <span class="text-charcoal/75">{f.range}</span>
                  {f.status === 'closed' && <span class="px-2 py-0.5 bg-wine/10 text-wine text-xs font-semibold rounded-full">Geschlossen</span>}
                  {f.status === 'reduced' && <span class="px-2 py-0.5 bg-gold/20 text-charcoal text-xs font-semibold rounded-full">Eingeschränkt</span>}
                  {f.status === 'normal' && <span class="px-2 py-0.5 bg-sage/20 text-charcoal text-xs font-semibold rounded-full">Normalbetrieb</span>}
                </div>
                {f.note && <p class="text-xs text-gray-muted mt-1">{f.note}</p>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="fade-in font-heading text-2xl font-bold text-dark mb-4">Dabei sein?</h2>
      <p class="fade-in text-charcoal/80 text-lg mb-8">
        Melde dich einfach per Telefon oder Kontaktformular an.
        Ich freue mich auf dich!
      </p>
      <div class="fade-in">
        <a href="/kontakt" class="btn btn-primary">Jetzt anmelden</a>
      </div>
    </div>
  </section>
</Layout>
