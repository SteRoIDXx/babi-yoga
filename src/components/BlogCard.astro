---
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  slug: string;
  image?: string;
  imageAlt?: string;
  videoUrl?: string;
}

const { title, date, excerpt, slug, image, imageAlt, videoUrl } = Astro.props;

const formattedDate = date.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="fade-in card group overflow-hidden p-0">
  {image && (
    <div class="aspect-[16/9] overflow-hidden relative">
      <img
        src={image}
        srcset={image?.endsWith('.webp') ? `${image.replace('.webp', '').replace('/images/', '/images/responsive/') + '-640w.webp'} 640w, ${image.replace('.webp', '').replace('/images/', '/images/responsive/') + '-1024w.webp'} 1024w, ${image} 1600w` : undefined}
        sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw"
        alt={imageAlt || title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
      />
      {/* Video-Play-Badge */}
      {videoUrl && (
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-14 h-14 rounded-full bg-wine/80 backdrop-blur-sm flex items-center justify-center shadow-lg group-hover:bg-wine group-hover:scale-110 transition-all duration-300">
            <svg class="w-6 h-6 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      )}
    </div>
  )}
  {/* Wenn kein Bild aber Video → Play-Platzhalter */}
  {!image && videoUrl && (
    <div class="aspect-[16/9] bg-gradient-to-br from-wine/10 to-wine/5 flex items-center justify-center">
      <div class="w-16 h-16 rounded-full bg-wine/80 flex items-center justify-center shadow-lg group-hover:bg-wine group-hover:scale-110 transition-all duration-300">
        <svg class="w-7 h-7 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
    </div>
  )}
  <div class="p-6">
    <time datetime={date.toISOString()} class="text-xs font-medium text-gray-muted uppercase tracking-wider">
      {formattedDate}
    </time>
    <h3 class="font-heading text-xl font-bold text-dark mt-2 mb-3 group-hover:text-wine transition-colors duration-300">
      <a href={`/blog/${slug}`} class="hover:text-wine">
        {title}
      </a>
    </h3>
    <p class="text-charcoal/70 text-sm leading-relaxed mb-4">
      {excerpt}
    </p>
    <a href={`/blog/${slug}`} class="inline-flex items-center gap-2 text-wine text-sm font-semibold hover:gap-3 transition-all duration-300">
      Weiterlesen<span class="sr-only">: {title}</span>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 12h14m-7-7l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
