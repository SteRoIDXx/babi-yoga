---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Desktop: 9 Kernseiten — klar & aufgeräumt
const desktopNavItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Yoga', href: '/yoga' },
  { label: 'Büro-Yoga', href: '/buero-yoga' },
  { label: 'Ayurveda', href: '/ayurveda' },
  { label: 'Preise', href: '/preise' },
  { label: 'Reisen', href: '/reisen' },
  { label: 'Über mich', href: '/ueber-mich' },
  { label: 'Blog', href: '/blog' },
  { label: 'Kontakt', href: '/kontakt' },
];

// Mobile: alle Seiten, logisch gruppiert
const mobileNavGroups = [
  {
    heading: 'Angebot',
    items: [
      { label: 'Yoga', href: '/yoga' },
      { label: 'Büro-Yoga', href: '/buero-yoga' },
      { label: 'Ayurveda & Massagen', href: '/ayurveda' },
      { label: 'Preise', href: '/preise' },
    ],
  },
  {
    heading: 'Erleben',
    items: [
      { label: 'Reisen & Retreats', href: '/reisen' },
      { label: 'Veranstaltungen', href: '/veranstaltungen' },
      { label: 'Mediathek', href: '/mediathek' },
      { label: 'Blog', href: '/blog' },
    ],
  },
  {
    heading: 'Mehr erfahren',
    items: [
      { label: 'Über mich', href: '/ueber-mich' },
      { label: 'Empfehlungen', href: '/empfehlungen' },
      { label: 'Kundenstimmen', href: '/kundenstimmen' },
    ],
  },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-30 transition-all duration-500 bg-warm-white/95 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center min-h-[44px] shrink-0">
        <img
          src="/images/babi-yoga-logo.webp"
          alt="Babi Yoga — Yoga in Neu Wulmstorf"
          class="h-12 sm:h-14 w-auto"
          width="643"
          height="178"
          loading="eager"
        />
      </a>

      <!-- Desktop Navigation — zentriert im Raum zwischen Logo und rechtem Rand -->
      <nav class="hidden lg:flex flex-1 items-center justify-center gap-1" aria-label="Hauptnavigation">
        {desktopNavItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link px-2.5 py-2 text-[0.8125rem] font-medium tracking-wide transition-colors duration-300 relative min-h-[44px] flex items-center whitespace-nowrap ${
              isActive(item.href)
                ? 'text-wine font-semibold'
                : 'text-charcoal hover:text-wine'
            }`}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-[5px] p-2 group min-w-[44px] min-h-[44px] items-center justify-center"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <span class="w-6 h-[2px] bg-charcoal transition-all duration-300 origin-center group-[.active]:rotate-45 group-[.active]:translate-y-[7px]"></span>
        <span class="w-6 h-[2px] bg-charcoal transition-all duration-300 group-[.active]:opacity-0"></span>
        <span class="w-6 h-[2px] bg-charcoal transition-all duration-300 origin-center group-[.active]:-rotate-45 group-[.active]:-translate-y-[7px]"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Navigation Overlay -->
<div id="nav-overlay" class="nav-overlay"></div>

<!-- Mobile Navigation Panel — gruppiert für bessere Übersicht -->
<nav id="mobile-nav" class="mobile-nav" aria-label="Mobile Navigation">
  <div class="flex flex-col h-full">
    <!-- Close Button -->
    <div class="flex justify-end mb-4">
      <button id="mobile-nav-close" class="p-2 text-charcoal min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Menü schließen">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Startseite -->
    <a
      href="/"
      class={`mobile-nav-link block px-4 py-3 text-lg font-semibold rounded-lg transition-all duration-300 min-h-[44px] mb-2 ${
        isActive('/')
          ? 'text-wine bg-wine/5'
          : 'text-charcoal hover:text-wine hover:bg-wine/5'
      }`}
      aria-current={isActive('/') ? 'page' : undefined}
    >
      Startseite
    </a>

    <!-- Gruppierte Navigation -->
    <div class="flex flex-col gap-5 overflow-y-auto">
      {mobileNavGroups.map((group) => (
        <div>
          <p class="px-4 text-[0.6875rem] font-bold tracking-[0.15em] uppercase text-charcoal mb-1">{group.heading}</p>
          <div class="flex flex-col">
            {group.items.map((item) => (
              <a
                href={item.href}
                class={`mobile-nav-link block px-4 py-3 text-base font-medium rounded-lg transition-all duration-300 min-h-[44px] ${
                  isActive(item.href)
                    ? 'text-wine bg-wine/5'
                    : 'text-charcoal hover:text-wine hover:bg-wine/5'
                }`}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Kontakt (prominent, unten) -->
    <div class="mt-auto pt-6 border-t border-sand-dark">
      <a
        href="/kontakt"
        class="mobile-nav-link block text-center py-3 text-base font-semibold text-wine rounded-full border-2 border-wine hover:bg-wine hover:text-white transition-all duration-300 min-h-[44px] mb-3"
      >
        Kontakt
      </a>
      <p class="text-center text-sm text-gray-muted">0171 588 4552</p>
    </div>
  </div>
</nav>

<script>
  // Header scroll behavior
  const header = document.getElementById('site-header');

  function updateHeader() {
    const scrollY = window.scrollY;
    if (scrollY > 20) {
      header?.classList.add('shadow-sm');
    } else {
      header?.classList.remove('shadow-sm');
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('nav-overlay');
  const mobileNav = document.getElementById('mobile-nav');
  const closeBtn = document.getElementById('mobile-nav-close');

  function openMenu() {
    menuBtn?.classList.add('active');
    menuBtn?.setAttribute('aria-expanded', 'true');
    overlay?.classList.add('active');
    mobileNav?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menuBtn?.classList.remove('active');
    menuBtn?.setAttribute('aria-expanded', 'false');
    overlay?.classList.remove('active');
    mobileNav?.classList.remove('active');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  overlay?.addEventListener('click', closeMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(135deg, var(--color-wine), var(--color-gold));
    transition: all 0.3s var(--ease-out-smooth);
    transform: translateX(-50%);
  }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    width: 60%;
  }
</style>
