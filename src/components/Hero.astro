---
// Hero Section — Full viewport with real background image
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Real background image -->
  <img
    src="/images/hero-bg.webp"
    alt="Meditation Hand-Mudra bei Sonnenuntergang"
    loading="eager"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <!-- Dark warm overlay so background image stays vivid -->
  <div class="absolute inset-0 bg-gradient-to-b from-night/55 via-night/40 to-night/65"></div>

  <!-- Decorative organic shapes (subtle on dark) -->
  <div class="organic-shape w-[600px] h-[600px] bg-white -top-40 -right-40" style="opacity: 0.04;"></div>
  <div class="organic-shape w-[400px] h-[400px] bg-gold bottom-20 -left-20" style="border-radius: 40% 60% 55% 45% / 55% 45% 55% 45%; opacity: 0.06;"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center py-32 lg:py-0">
    <!-- Subtle label -->
    <div class="fade-in mb-6">
      <span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-white/70">Yoga &middot; Ayurveda &middot; Massagen</span>
    </div>

    <!-- Main Headline -->
    <h1 class="fade-in font-heading text-dark leading-[1.1] mb-8" style="font-size: var(--text-hero); text-shadow: 0 1px 6px rgba(0,0,0,0.4);">
      Raus aus dem Alltag,<br />
      <span class="italic">rein in die Entspannung.</span>
    </h1>

    <!-- Tagline -->
    <p class="fade-in text-xl md:text-2xl text-white/80 font-light mb-4 font-heading italic" style="text-shadow: 0 1px 8px rgba(0,0,0,0.3);">
      &bdquo;Der Trick ist zu atmen!&ldquo;
    </p>

    <!-- Descriptors -->
    <div class="fade-in flex flex-wrap items-center justify-center gap-2 sm:gap-5 text-xs sm:text-base text-white/60 font-medium tracking-wide mb-12">
      <span>Bewegung</span>
      <span class="w-1 h-1 rounded-full bg-gold"></span>
      <span>Achtsamkeit</span>
      <span class="w-1 h-1 rounded-full bg-gold"></span>
      <span>Balance</span>
      <span class="w-1 h-1 rounded-full bg-gold"></span>
      <span>Innenschau</span>
    </div>

    <!-- CTAs -->
    <div class="fade-in flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/yoga" class="btn btn-primary">
        Yogakurs entdecken
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" /></svg>
      </a>
      <a href="/ueber-mich" class="btn bg-white/15 text-white border border-white/30 hover:bg-white/25 backdrop-blur-sm rounded-full px-6 py-3 text-sm font-semibold transition-all duration-300 inline-flex items-center gap-2">Über mich</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 fade-in">
    <div class="w-6 h-10 rounded-full border-2 border-white/30 flex justify-center pt-2">
      <div class="w-1 h-2.5 rounded-full bg-gold/70 animate-bounce"></div>
    </div>
  </div>
</section>
