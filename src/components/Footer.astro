---
const footerLinks = [
  { label: 'Yoga', href: '/yoga' },
  { label: 'Büro-Yoga', href: '/buero-yoga' },
  { label: 'Ayurveda & Massagen', href: '/ayurveda' },
  { label: 'Preise', href: '/preise' },
  { label: 'Reisen & Retreats', href: '/reisen' },
  { label: 'Veranstaltungen', href: '/veranstaltungen' },
  { label: 'Mediathek', href: '/mediathek' },
  { label: 'Empfehlungen', href: '/empfehlungen' },
  { label: 'Kundenstimmen', href: '/kundenstimmen' },
  { label: 'Blog', href: '/blog' },
  { label: 'Über mich', href: '/ueber-mich' },
];

const legalLinks = [
  { label: 'Impressum', href: '/impressum' },
  { label: 'Datenschutz', href: '/datenschutz' },
  { label: 'AGB', href: '/agb' },
  { label: 'Widerrufsbelehrung', href: '/widerrufsbelehrung' },
];

const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/nikola.babi/', icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
