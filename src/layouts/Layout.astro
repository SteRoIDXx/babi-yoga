---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title = 'Babi Yoga — Yoga, Ayurveda & Massagen in Neu Wulmstorf',
  description = 'Yoga, Ayurveda und Massagen in Neu Wulmstorf bei Hamburg. Hatha Yoga, Yin Yoga, Kinderyoga, Ayurvedische Massagen und Präventionskurse mit Krankenkassenzuschuss.',
  ogTitle,
  ogImage = '/images/og-default.jpg',
  canonicalUrl,
  noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = 'https://babi-yoga.com';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const absoluteOgImage = ogImage?.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>

    <!-- Canonical URL -->
    {!noindex && <link rel="canonical" href={canonical} />}
    <link rel="alternate" hreflang="de" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Babi Yoga" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Fonts: Self-hosted Playfair Display + Work Sans (kein externer Request) -->
    <link rel="preload" href="/fonts/playfair-display-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/work-sans-400.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- JSON-LD Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HealthAndBeautyBusiness",
      "name": "Babi Yoga",
      "alternateName": "Babi-Yoga Nikola Babi",
      "url": "https://babi-yoga.com",
      "telephone": "+491715884552",
      "email": "info@babi-yoga.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Fischbeker Str. 4",
        "addressLocality": "Neu Wulmstorf",
        "postalCode": "21629",
        "addressRegion": "Niedersachsen",
        "addressCountry": "DE"
      },
      "description": "Yoga, Ayurveda und Massagen in Neu Wulmstorf bei Hamburg. Hatha Yoga, Yin Yoga, Kinderyoga, Ayurvedische Massagen und Präventionskurse.",
      "founder": {
        "@type": "Person",
        "name": "Nikola Babi",
        "jobTitle": "Yogalehrerin & Ayurveda-Beraterin"
      },
      "image": "https://babi-yoga.com/images/og-default.jpg",
      "priceRange": "$$",
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 53.4631,
        "longitude": 9.7978
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "20:00"
        }
      ],
      "sameAs": [
        "https://www.facebook.com/nikola.babi/",
        "https://www.instagram.com/babi_nikola/",
        "https://www.youtube.com/@nikolababi-yoga",
        "https://www.linkedin.com/in/nikola-babi-a5588a1b1/"
      ]
    })} />
  </head>
  <body>
    <!-- Skip-to-Content (Accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:bg-wine focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:z-[100] focus:text-sm focus:font-medium"
    >
      Zum Inhalt springen
    </a>

    <Header currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Cookie-Banner (keine Cookies, rein informativ) -->
    <div
      id="privacy-banner"
      role="status"
      class="fixed bottom-0 left-0 right-0 z-[999] translate-y-full transition-transform duration-500 ease-out"
    >
      <div class="max-w-5xl mx-auto px-5 sm:px-8 pb-5">
        <div class="flex items-center justify-between gap-4 bg-night/95 backdrop-blur-sm text-white/80 text-[13px] leading-relaxed px-5 py-3.5 rounded-lg shadow-lg border border-white/5">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <p>Diese Website verwendet keine Cookies und kein Tracking. Deine Daten bleiben bei dir. <a href="/datenschutz" class="underline text-gold hover:text-gold-light">Mehr erfahren</a></p>
          </div>
          <button
            id="privacy-banner-close"
            aria-label="Hinweis schließen"
            class="shrink-0 w-7 h-7 flex items-center justify-center rounded hover:bg-white/10 transition-colors text-white/50 hover:text-white/80"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- IntersectionObserver + Cookie-Banner Script -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.fade-in, .fade-in-left, .fade-in-right').forEach((el) => {
        observer.observe(el);
      });

      // Cookie-Banner
      const privacyBanner = document.getElementById('privacy-banner');
      const privacyClose = document.getElementById('privacy-banner-close');
      if (privacyBanner && privacyClose) {
        if (!localStorage.getItem('privacy-dismissed')) {
          setTimeout(() => {
            privacyBanner.classList.remove('translate-y-full');
            privacyBanner.classList.add('translate-y-0');
          }, 1500);
        }
        privacyClose.addEventListener('click', () => {
          privacyBanner.classList.remove('translate-y-0');
          privacyBanner.classList.add('translate-y-full');
          localStorage.setItem('privacy-dismissed', '1');
        });
      }
    </script>
  </body>
</html>
