---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { generateCsrfToken } from '../../lib/auth';

const csrfToken = generateCsrfToken();
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
const user = Astro.locals.user;

const errorMessages: Record<string, string> = {
  missing: 'Bitte alle Felder ausfüllen.',
  short: 'Das neue Passwort muss mindestens 8 Zeichen haben.',
  invalid: 'Ungültige Eingabe.',
  mismatch: 'Die neuen Passwörter stimmen nicht überein.',
  same: 'Das neue Passwort darf nicht dem alten entsprechen.',
  wrong: 'Das aktuelle Passwort ist falsch.',
  csrf: 'Sitzung abgelaufen. Bitte erneut versuchen.',
  server: 'Ein Fehler ist aufgetreten. Bitte erneut versuchen.',
};
---

<AdminLayout title="Passwort ändern" activeNav="password">
  <h1 class="page-title">Passwort ändern</h1>

  <div style="max-width: 480px;">
    {success && (
      <div class="alert alert-success">
        ✓ Dein Passwort wurde erfolgreich geändert.
      </div>
    )}

    {error && errorMessages[error] && (
      <div class="alert alert-error">
        {errorMessages[error]}
      </div>
    )}

    <div class="card">
      <p style="font-size: 0.875rem; color: var(--gray-muted); margin-bottom: 1.5rem;">
        Angemeldet als <strong>{user?.email}</strong>
      </p>

      <form method="POST" action="/api/auth/change-password">
        <input type="hidden" name="_csrf" value={csrfToken} />

        <div class="form-group">
          <label for="current_password">Aktuelles Passwort</label>
          <input
            type="password"
            id="current_password"
            name="current_password"
            required
            maxlength="128"
            autocomplete="current-password"
          />
        </div>

        <hr style="border: none; border-top: 1px solid var(--sand); margin: 1.5rem 0;" />

        <div class="form-group">
          <label for="new_password">Neues Passwort</label>
          <input
            type="password"
            id="new_password"
            name="new_password"
            required
            minlength="8"
            maxlength="128"
            autocomplete="new-password"
          />
          <small style="display: block; margin-top: 0.375rem; font-size: 0.8125rem; color: var(--gray-muted);">
            Mindestens 8 Zeichen
          </small>
        </div>

        <div class="form-group">
          <label for="confirm_password">Neues Passwort bestätigen</label>
          <input
            type="password"
            id="confirm_password"
            name="confirm_password"
            required
            minlength="8"
            maxlength="128"
            autocomplete="new-password"
          />
        </div>

        <div style="display: flex; gap: 0.75rem; align-items: center; margin-top: 0.5rem;">
          <button type="submit" class="btn btn-primary">Passwort ändern</button>
          <a href="/admin/" class="btn btn-secondary">Abbrechen</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>
