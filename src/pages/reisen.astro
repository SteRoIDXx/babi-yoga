---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Reisen & Retreats — Babi Yoga"
  description="Yoga-Retreats und Workshops mit Nikola Babi. Nächstes Retreat: Pfingsten 2026 im Wendland. Hatha Yoga, Ayurveda-Vollpension und Tiefenentspannung."
>
  <PageHero
    title="Reisen & Retreats"
    subtitle="Raus aus dem Alltag! Rein in die Entspannung!"
    backgroundImage="/images/yoga-retreat.webp"
    imagePosition="center 45%"
  />

  <!-- Intro -->
  <section class="section-padding bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="fade-in text-charcoal/85 text-lg leading-relaxed">
        Yoga und Ayurveda besser kennenlernen und tiefer in die Praxis eintauchen.
        Meine Retreats bieten dir die Möglichkeit, fernab vom Alltag zu dir selbst zu finden —
        in kleinen Gruppen, an kraftvollen Orten und mit liebevoller Betreuung.
      </p>
    </div>
  </section>

  <!-- Retreat Highlight -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in">
        <div class="bg-white rounded-2xl overflow-hidden shadow-md border border-sand-dark">
          <!-- Image -->
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src="/images/pfingsten-gruppe.webp"
              alt="Yoga-Retreat Gruppe bei gemeinsamer Heldenhaltung im Freien"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover object-top"
            />
          </div>

          <!-- Header -->
          <div class="bg-gradient-to-r from-wine to-magenta p-6 sm:p-8 text-white">
            <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-xs font-semibold mb-4 backdrop-blur-sm">
              Nächste Reise
            </span>
            <h3 class="font-heading text-2xl sm:text-3xl font-bold mb-2">
              Yogaretreat zu Pfingsten 2026
            </h3>
            <p class="text-white/80">im wunderschönen Wendland, Niedersachsen</p>
          </div>

          <!-- Details -->
          <div class="p-6 sm:p-8">
            <div class="grid sm:grid-cols-2 gap-6 mb-6">
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-wine/8 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-charcoal">22. – 25. Mai 2026</p>
                    <p class="text-sm text-gray-muted">Freitag 17:00 Uhr bis Pfingstmontag 13:00 Uhr</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-wine/8 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-charcoal">Göhrde im Wendland</p>
                    <p class="text-sm text-gray-muted">4 Tage / 3 Nächte</p>
                  </div>
                </div>
              </div>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-wine/8 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" /></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-charcoal">Einzel- oder Doppelzimmer</p>
                    <p class="text-sm text-gray-muted">Ayurvedisch-vegetarische Vollpension inklusive</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-wine/8 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342" /></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-charcoal">Yoga, Meditation, Mantras</p>
                    <p class="text-sm text-gray-muted">Entspannung & Ausflüge in die Region</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="p-4 bg-wine/5 rounded-xl border border-wine/10 mb-6">
              <p class="text-sm text-charcoal">
                <strong>Preis auf Anfrage</strong> — Einzel- und Doppelzimmer verfügbar.
                Es gibt immer einen Sozialplatz!
              </p>
            </div>

            <div class="text-center">
              <a href="/kontakt" class="btn btn-primary">Jetzt anfragen</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Retreat Impressions -->
  <section class="section-padding bg-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="fade-in font-heading text-2xl font-bold text-dark mb-3 text-center">Impressionen</h2>
      <p class="fade-in text-charcoal/70 text-center mb-8">Eindrücke von unseren bisherigen Retreats</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="fade-in rounded-xl overflow-hidden aspect-square">
          <img src="/images/yoga-wochenende-105.webp" alt="Yoga-Handgeste während einer Retreat-Übung" loading="lazy" decoding="async" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="fade-in rounded-xl overflow-hidden aspect-square">
          <img src="/images/yoga-wochenende-30.webp" alt="Yoga-Session im stimmungsvollen Raum mit großen Fenstern" loading="lazy" decoding="async" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="fade-in rounded-xl overflow-hidden aspect-square">
          <img src="/images/sonnengruesse.webp" alt="Nikola meditiert in der Heidelandschaft" loading="lazy" decoding="async" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="fade-in font-heading text-2xl font-bold text-dark mb-4">Lust bekommen?</h2>
      <p class="fade-in text-charcoal/80 text-lg mb-8">
        Sichere dir deinen Platz beim nächsten Retreat.
        Ich freue mich auf deine Nachricht!
      </p>
      <div class="fade-in">
        <a href="/kontakt" class="btn btn-primary">Jetzt Platz anfragen</a>
      </div>
    </div>
  </section>
</Layout>
