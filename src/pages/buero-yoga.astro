---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Büro-Yoga — Yoga am Arbeitsplatz | Babi Yoga"
  description="Yoga im Büro für Unternehmen in der Region Hamburg. Stressreduktion, Rückengesundheit und bessere Work-Life-Balance. Steuerlich absetzbar bis 600 € pro Mitarbeiter."
>
  <PageHero
    title="Yoga im Büro"
    subtitle="Ihr Erfolgsrezept für gesunde, motivierte Mitarbeiter."
    backgroundImage="/images/buero-yoga-1741.webp"
    imagePosition="center 35%"
  />

  <!-- Intro -->
  <section class="section-padding bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in space-y-6 text-charcoal/85 text-lg leading-relaxed text-center">
        <p>
          Yoga im Büro ist Ihr Erfolgsrezept, um Stress, Schulter-Nacken- und Rückenbeschwerden präventiv zu begegnen.
        </p>
        <p>
          Mit Yoga am Arbeitsplatz investieren Sie nicht nur in die Gesundheit und das Wohlbefinden Ihrer Mitarbeiter,
          sondern profitieren auch von steuerlichen Vorteilen und einer verbesserten Work-Life-Balance,
          die sich positiv auf die gesamte Unternehmenskultur auswirken.
        </p>
        <p>
          Ob Yoga, Atemtraining, Entspannungs- oder Meditationskurse, Workshops zur Selbstführung
          oder Impulse für Führungskräfte — statt standardisierter Programme entwickle ich in Absprache
          mit Ihnen klare, strukturierte Formate, individuell auf Struktur und Kultur Ihres Unternehmens abgestimmt.
        </p>
      </div>
    </div>
  </section>

  <!-- Benefits — mit Hintergrundbild -->
  <section class="section-padding relative overflow-hidden">
    <img
      src="/images/buero-yoga-1733.webp"
      alt=""
      role="presentation"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: center 35%;"
    />
    <div class="absolute inset-0 bg-night/60"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h2 class="fade-in font-heading text-2xl font-bold text-center text-white mb-12">Ihre Vorteile</h2>
      <div class="fade-in grid sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="w-14 h-14 rounded-full bg-wine/10 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-wine" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <h4 class="font-heading font-bold text-lg text-dark mb-2">Vor Ort oder Online</h4>
          <p class="text-charcoal/70 text-sm leading-relaxed">Flexible Formate, angepasst an Ihren Unternehmensalltag</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="w-14 h-14 rounded-full bg-wine/10 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-wine" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h4 class="font-heading font-bold text-lg text-dark mb-2">Steuerlich absetzbar</h4>
          <p class="text-charcoal/70 text-sm leading-relaxed">Bis zu 600 € pro Mitarbeiter/Jahr steuer- und sozialversicherungsfrei</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="w-14 h-14 rounded-full bg-wine/10 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-wine" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h4 class="font-heading font-bold text-lg text-dark mb-2">Individuell</h4>
          <p class="text-charcoal/70 text-sm leading-relaxed">Maßgeschneiderte Programme statt Standard-Lösungen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-warm-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="fade-in font-heading text-2xl font-bold text-dark mb-4">Interesse geweckt?</h2>
      <p class="fade-in text-charcoal/80 text-lg mb-8">
        Lassen Sie uns gemeinsam das passende Format für Ihr Unternehmen finden.
        Die Erstberatung ist kostenfrei und unverbindlich.
      </p>
      <div class="fade-in">
        <a href="/kontakt" class="btn btn-primary">Kostenfreie Erstberatung buchen</a>
      </div>
    </div>
  </section>
</Layout>
