---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Kontakt — Babi Yoga in Neu Wulmstorf"
  description="Kontaktiere Babi Yoga in Neu Wulmstorf. Yoga-Kurse buchen, Massage-Termin vereinbaren oder Fragen stellen. Tel: 0171 588 4552."
>
  <PageHero
    title="Kontakt"
    subtitle="Ich freue mich auf deine Nachricht."
    backgroundImage="/images/kontakt-banner.webp"
    imagePosition="center 25%"
  />

  <!-- Kontaktinfo + Formular -->
  <section class="section-padding bg-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-start">

        <!-- Linke Spalte: Kontaktdaten -->
        <div class="lg:col-span-2 fade-in-left">
          <h2 class="font-heading text-2xl font-bold text-dark mb-6">So erreichst du mich</h2>

          <div class="space-y-6">
            <!-- Telefon -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-wine/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="font-medium text-dark text-sm mb-1">Telefon</p>
                <a href="tel:+491715884552" class="text-charcoal/80 hover:text-wine transition-colors">0171 588 4552</a>
              </div>
            </div>

            <!-- E-Mail -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-wine/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <p class="font-medium text-dark text-sm mb-1">E-Mail</p>
                <a href="mailto:info@babi-yoga.com" class="text-charcoal/80 hover:text-wine transition-colors">info@babi-yoga.com</a>
              </div>
            </div>

            <!-- Adresse -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-wine/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-wine" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <p class="font-medium text-dark text-sm mb-1">Adresse</p>
                <p class="text-charcoal/80">Fischbeker Str. 4<br />21629 Neu Wulmstorf</p>
              </div>
            </div>
          </div>

          <!-- Hinweis -->
          <div class="mt-8 p-4 bg-gold/8 border border-gold/20 rounded-xl">
            <p class="text-sm text-charcoal/70 leading-relaxed">
              Du kannst mich auch gerne direkt anrufen oder eine E-Mail schreiben — ich melde mich so schnell wie möglich zurück.
            </p>
          </div>
        </div>

        <!-- Rechte Spalte: Formular -->
        <div class="lg:col-span-3 fade-in-right">
          <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-sand-dark">
            <h3 class="font-heading text-xl font-bold text-dark mb-6">Schreib mir</h3>

            <form id="contact-form" class="space-y-5">
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-dark mb-1.5">Name</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-sand-dark bg-white text-charcoal placeholder-gray-muted/50 focus:outline-none focus:border-wine focus:ring-2 focus:ring-wine/10 transition-all duration-300"
                    placeholder="Dein Name"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-dark mb-1.5">E-Mail</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-sand-dark bg-white text-charcoal placeholder-gray-muted/50 focus:outline-none focus:border-wine focus:ring-2 focus:ring-wine/10 transition-all duration-300"
                    placeholder="deine@email.de"
                  />
                </div>
              </div>
              <div>
                <label for="subject" class="block text-sm font-medium text-dark mb-1.5">Betreff</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-3 rounded-xl border border-sand-dark bg-white text-charcoal focus:outline-none focus:border-wine focus:ring-2 focus:ring-wine/10 transition-all duration-300"
                >
                  <option value="">Bitte wählen...</option>
                  <option value="Yogakurs">Yogakurs</option>
                  <option value="Massage / Ayurveda">Massage / Ayurveda</option>
                  <option value="Büro-Yoga / BGF">Büro-Yoga / BGF</option>
                  <option value="Reise / Workshop">Reise / Workshop</option>
                  <option value="1:1 Coaching">1:1 Coaching</option>
                  <option value="Sonstiges">Sonstiges</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-dark mb-1.5">Nachricht</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-sand-dark bg-white text-charcoal placeholder-gray-muted/50 focus:outline-none focus:border-wine focus:ring-2 focus:ring-wine/10 transition-all duration-300 resize-none"
                  placeholder="Deine Nachricht..."
                ></textarea>
              </div>
              <div class="pt-2">
                <button type="submit" class="btn btn-primary w-full sm:w-auto">
                  Nachricht senden
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" /></svg>
                </button>
              </div>
              <p class="text-xs text-gray-muted mt-2">
                Es öffnet sich dein E-Mail-Programm mit den vorausgefüllten Daten.
              </p>
            </form>

            <script>
              document.getElementById('contact-form')?.addEventListener('submit', function(e) {
                e.preventDefault();
                const name = document.getElementById('name').value;
                const email = document.getElementById('email').value;
                const subject = document.getElementById('subject').value || 'Kontaktanfrage';
                const message = document.getElementById('message').value;

                const body = `Name: ${name}\nE-Mail: ${email}\n\n${message}`;
                const mailto = `mailto:info@babi-yoga.com?subject=${encodeURIComponent('Kontaktanfrage: ' + subject)}&body=${encodeURIComponent(body)}`;
                window.location.href = mailto;
              });
            </script>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
